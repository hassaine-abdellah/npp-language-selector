#include "resource.h"
#define IDC_STATIC      -1
#define IDOK      1
#define IDCANCEL      2

#define DS_SETFONT      0x40L
#define DS_MODALFRAME   0x80L
#define DS_CENTER       0x800L
#define WS_POPUP        0x80000000L
#define WS_CAPTION      0x00C00000L
#define WS_SYSMENU      0x00080000L
#define WS_TABSTOP      0x00010000L
#define WS_VSCROLL      0x00200000L
#define CBS_DROPDOWNLIST 0x0003L
#define CBS_HASSTRINGS  0x0200L
#define CBS_OWNERDRAWFIXED 0x0010L
#define SS_LEFT         0x00000000L
#define WS_CLIPCHILDREN 0x02000000L
IDD_LANGUAGE_DIALOG DIALOGEX 0, 0, 180, 60
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER| WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_CLIPCHILDREN
CAPTION "Select Language"
FONT 12, "Segoe UI"
BEGIN
LTEXT           "Select the programming language for this tab:",
IDC_STATIC, 10, 8, 245, 14

COMBOBOX        IDC_COMBO_LANG, 10, 23, 100, 120,
CBS_DROPDOWNLIST | CBS_HASSTRINGS | CBS_OWNERDRAWFIXED |
WS_VSCROLL | WS_TABSTOP

AUTOCHECKBOX    "Favourite",
IDC_CHECK_FAVORITE, 125, 20, 72, 16, WS_TABSTOP

DEFPUSHBUTTON   "OK", IDOK, 30, 47,40, 10, WS_TABSTOP
PUSHBUTTON      "Cancel", IDCANCEL, 110, 47, 40, 10, WS_TABSTOP
END

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 180, 60
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_CLIPCHILDREN
CAPTION "Language Selector Settings"
FONT 12, "Segoe UI"
BEGIN
LTEXT           "Maximum favourite items:",
IDC_LIMIT_LABEL, 10, 10, 125, 14

COMBOBOX        IDC_LIMIT_COMBO, 100, 10, 30, 80,
CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_TABSTOP

AUTOCHECKBOX    "Show automatically on new tabs",
IDC_AUTOSHOW_CHECK, 10, 25, 195, 14,
WS_TABSTOP

PUSHBUTTON      "Apply", IDC_APPLY_BTN, 30, 47,40, 10, WS_TABSTOP
PUSHBUTTON      "Cancel", IDCANCEL, 110, 47, 40, 10, WS_TABSTOP
END